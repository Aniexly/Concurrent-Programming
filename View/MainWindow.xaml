<Window x:Class="View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:View"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Orientation="Vertical" Margin="16" VerticalAlignment="Center">
            <TextBlock Text="Balls count" FontSize="14" Margin="8,8,8,0" TextAlignment="Center" />
            <TextBox Width="104" Height="32" Visibility="Visible" Margin="8"/>
            <Button Content="Add ball" Width="104" Height="32" Background="Green" Margin="8"/>
            <Button Content="Remove ball" Width="104" Height="32" Background="Red" Margin="8"/>
            <Button Content="Start" Width="104" Height="32" Margin="8"/>
        </StackPanel>
        <Grid Grid.Column="1">
            <Rectangle Width="583" Height="375" Stroke="Gray" Fill="LightGray" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>